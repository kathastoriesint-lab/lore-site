{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feed/**",
              "components/live/**",
              "components/meters/**",
              "components/worlds/**",
              "ui_kits/lore-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Poppins))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Poppins."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initial|color|key|ref|className|style|children)$/]",
        "message": "<AvatarItem> doesn't accept that prop. Declared props: src, initial, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pulse'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|style|key|ref|className|style|children)$/]",
        "message": "<Pulse> doesn't accept that prop. Declared props: color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|iconLeft|iconRight|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, iconLeft, iconRight, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|light)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm|pill)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|chosen|dimmed|socialProof|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ChoiceCard> doesn't accept that prop. Declared props: title, subtitle, chosen, dimmed, socialProof, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|kind|color|style|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: label, value, kind, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:fame|heat|trust|image)$/]",
        "message": "<Meter> kind must be one of 'fame' | 'heat' | 'trust' | 'image'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HUDMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|kind|key|ref|className|style|children)$/]",
        "message": "<HUDMeter> doesn't accept that prop. Declared props: label, value, kind."
      },
      {
        "selector": "JSXOpeningElement[name.name='HUDMeter'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:fame|heat|trust|image)$/]",
        "message": "<HUDMeter> kind must be one of 'fame' | 'heat' | 'trust' | 'image'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PostReaction'] > JSXAttribute > JSXIdentifier[name!=/^(?:handle|text|key|ref|className|style|children)$/]",
        "message": "<PostReaction> doesn't accept that prop. Declared props: handle, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReactionBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|text|color|avatarSrc|avatarInitial|style|key|ref|className|style|children)$/]",
        "message": "<ReactionBubble> doesn't accept that prop. Declared props: name, text, color, avatarSrc, avatarInitial, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SituationHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|title|paragraphs|narrationButton|style|key|ref|className|style|children)$/]",
        "message": "<SituationHeader> doesn't accept that prop. Declared props: tag, title, paragraphs, narrationButton, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryDrop'] > JSXAttribute > JSXIdentifier[name!=/^(?:badge|badgeColor|title|teaser|cover|imageUrl|cta|onPlay|style|key|ref|className|style|children)$/]",
        "message": "<StoryDrop> doesn't accept that prop. Declared props: badge, badgeColor, title, teaser, cover, imageUrl, cta, onPlay, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorldCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|teaser|cover|imageUrl|status|statusColor|live|locked|coverHeight|cast|meta|ringColor|onClick|style|key|ref|className|style|children)$/]",
        "message": "<WorldCard> doesn't accept that prop. Declared props: name, teaser, cover, imageUrl, status, statusColor, live, locked, coverHeight, cast, meta, ringColor, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
